# Copy these values to your system environment or VS Code environment settings
# before starting MCP servers.

# Required for GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Required for SearXNG MCP (self-hosted or public instance)
SEARXNG_BASE_URL=http://localhost:8080

# Optional override for SQLite MCP data path
MCP_SQLITE_DB_PATH=./data/mcp.sqlite

# Optional: if using env interpolation in MCP configs for future servers,
# keep Mongo mode values here for consistency with backend runtime.
MONGODB_MODE=auto
MONGODB_FALLBACK_MODE=off
