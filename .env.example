# Sarvam AI Configuration
# Get your API key from https://sarvam.ai/

# -----------------------------
# Frontend Runtime
# -----------------------------

# Base URL for ShieldRide backend APIs
VITE_API_BASE_URL=http://localhost:4000/api

# Sarvam API Key (required for production use)
VITE_SARVAM_API_KEY=your_api_key_here

# Sarvam STT (Speech-to-Text) API Endpoint
# Uses Saaras v3 for transcription
VITE_SARVAM_STT_URL=https://api.saaras.ai/v1/stt

# Sarvam TTS (Text-to-Speech) API Endpoint
# Uses Bulbul v3 for speech synthesis
VITE_SARVAM_TTS_URL=https://api.bulbul.ai/v1/tts

# -----------------------------
# Backend Runtime
# -----------------------------

# MongoDB mode:
# - auto: try local first, then Atlas
# - local: force local MongoDB
# - atlas: force MongoDB Atlas
# - memory: force embedded in-memory MongoDB
MONGODB_MODE=auto

# Local MongoDB URI (persistent)
MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/shieldride

# Atlas MongoDB URI (persistent)
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/shieldride?retryWrites=true&w=majority
MONGODB_ATLAS_URI=

# Optional direct override URI (if set, this is attempted first)
MONGODB_URI=

# Mongo fallback mode:
# - memory: use embedded MongoDB when MONGODB_URI is unavailable
# - off: fail startup if MONGODB_URI cannot be reached
MONGODB_FALLBACK_MODE=off

# JWT secret for authentication
JWT_SECRET=replace_with_a_secure_secret

# Comma-separated list of allowed frontend origins for credentialed CORS.
# Example: http://localhost:3000,https://guidewire.example.com
# In production, you should set this explicitly.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth endpoint throttling settings
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40

# Weather API timeout in milliseconds
WEATHER_TIMEOUT_MS=5000

# In non-production runtimes, allow implicit in-memory Mongo fallback on persistent DB failures.
# Set to off to enforce strict persistent-only startup behavior.
DEV_IMPLICIT_MEMORY_FALLBACK=on

# Backend API port
API_PORT=4000

# Request payload limits to reduce 413 errors for large request bodies
API_JSON_LIMIT=10mb
API_URLENCODED_LIMIT=10mb

# Default insurer credentials (seeded automatically if missing)
INSURER_EMAIL=insurer@shieldride.ai
INSURER_PASSWORD=Insurer@123
