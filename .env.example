# Sarvam AI Configuration
# Get your API key from https://sarvam.ai/

# Sarvam API Key (required for production use)
VITE_SARVAM_API_KEY=your_api_key_here

# Sarvam STT (Speech-to-Text) API Endpoint
# Uses Saaras v3 for transcription
VITE_SARVAM_STT_URL=https://api.saaras.ai/v1/stt

# Sarvam TTS (Text-to-Speech) API Endpoint
# Uses Bulbul v3 for speech synthesis
VITE_SARVAM_TTS_URL=https://api.bulbul.ai/v1/tts
