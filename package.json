{
  "name": "guidewire",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "start:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:smoke:api": "node scripts/smoke-api.mjs",
    "test:unit": "node scripts/tests/test-unit.mjs",
    "test:integration": "node scripts/tests/test-integration.mjs",
    "test:contract": "node scripts/tests/test-contract.mjs",
    "test:resilience": "node scripts/tests/test-resilience.mjs",
    "test:security": "node scripts/tests/test-security.mjs",
    "test:performance": "node scripts/tests/test-performance.mjs",
    "test:a11y": "node scripts/tests/test-a11y.mjs",
    "test:quality": "npm run test:unit && npm run test:integration && npm run test:contract && npm run test:resilience && npm run test:security && npm run test:performance && npm run test:a11y",
    "test:smoke:ui": "playwright test -c playwright.smoke.config.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express-rate-limit": "^8.1.0",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.19.3",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.0.1"
  }
}
